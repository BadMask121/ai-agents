# ─── booking-ops environment ───────────────────────────────────────────────
# Copy to .env (local) or set these as Coolify Environment Variables (prod).

# Anthropic (drafting + ChatGPT distillation). Shared with the rest of the repo.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Model for drafting replies. Haiku is the cost-optimal default (see docs/booking-ops/07).
BOOKING_MODEL=claude-haiku-4-5-20251001

# Google OAuth app (type: "Web application"). Register GOOGLE_REDIRECT_URI below
# as an authorized redirect URI. NO refresh token here — accounts are linked at
# runtime via the Telegram /connect web flow (tokens saved per-account in the workspace).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
# Public callback for the /connect web flow. Must match a redirect URI on the
# OAuth client. Leave unset to disable /connect (then link via the auth:local CLI).
GOOGLE_REDIRECT_URI=https://booking.yourdomain.com/oauth/callback
# Port the OAuth callback server listens on (Coolify maps the domain here).
OAUTH_PORT=8080

# Telegram bot (BotFather). TELEGRAM_CHAT_ID is the single authorized chat (you).
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Loops.so — lead store. API key from Loops Settings → API.
LOOPS_API_KEY=...

# Workspace + behaviour.
BOOKING_OPS_WORKSPACE=/workspace/booking-ops
# IANA timezone used for calendar events when a client's own TZ is unknown.
BOOKING_TIMEZONE=Europe/London
# How often (seconds) to poll Gmail for new mail.
GMAIL_POLL_SECONDS=90
