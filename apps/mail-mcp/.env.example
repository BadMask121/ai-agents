# --- Required ---
PRIVATEEMAIL_USER=you@yourdomain.com
PRIVATEEMAIL_PASS=your-mailbox-password
# Long random URL segment. Generate e.g.: openssl rand -hex 24
MCP_SECRET_PATH=change-me-to-a-long-random-string

# --- Optional (privateemail defaults shown) ---
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
PORT=8080
MAX_BODY_BYTES=100000
MAX_ATTACHMENT_BYTES=5000000
