{
  "name": "@ai-agents/mail-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Remote MCP server exposing a privateemail.com (Open-Xchange) mailbox to ChatGPT over Streamable HTTP.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.0.196",
    "mailparser": "^3.7.2",
    "nodemailer": "^6.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^2.1.8"
  }
}
