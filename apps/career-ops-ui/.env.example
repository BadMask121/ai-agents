# Required
# 32+ character random string, used to sign session cookies
AUTH_SECRET=

# bcrypt hash of your login password
# generate with: npm run hash:password -- 'your password here'
AUTH_PASSWORD_HASH=

# Anthropic API key for Claude Code subprocess
ANTHROPIC_API_KEY=

# Path on the container's filesystem to the career-ops workspace
# In Docker this is bind-mounted from the host
CAREER_OPS_WORKSPACE=/workspace/career-ops
